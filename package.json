{
  "name": "orbitlab",
  "version": "0.1.0",
  "private": true,
  "description": "Web-first 3D rocket design, simulation, and education platform",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/meviza/orbitlab.git"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:web": "pnpm --filter @orbitlab/web build",
    "ci": "pnpm typecheck && pnpm test && pnpm build:web",
    "dev": "pnpm --filter @orbitlab/web dev",
    "desktop:dev": "pnpm --filter @orbitlab/desktop dev",
    "desktop:build": "pnpm --filter @orbitlab/desktop build",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "pb:download": "pnpm --filter @orbitlab/pocketbase download",
    "pb:serve": "pnpm --filter @orbitlab/pocketbase serve",
    "pb:import": "pnpm --filter @orbitlab/pocketbase import-schema",
    "check:docs": "node -e \"require('fs').accessSync('docs/PRODUCT.md')\""
  },
  "engines": {
    "node": ">=20"
  }
}
