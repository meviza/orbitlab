# OrbitLab web — data backend selection
# Copy to .env and restart the Vite dev server after changes.

# memory (default) — offline guest session + in-memory repos, no PocketBase required
# pocketbase        — AuthPort + design/sim-run repos against a PocketBase instance
VITE_DATA_BACKEND=memory

# Used only when VITE_DATA_BACKEND=pocketbase
VITE_POCKETBASE_URL=http://127.0.0.1:8090
