# Copy to .env and fill in (never commit .env)
#   cp .env.example .env

# Superuser for Admin UI + schema import scripts
PB_ADMIN_EMAIL=admin@orbitlab.local
PB_ADMIN_PASSWORD=change-me-to-a-long-random-secret

# Bind address for `pnpm serve` (host:port, no scheme)
PB_HTTP=127.0.0.1:8090

# Full base URL for import-schema / CI (wins over PB_HTTP when set)
POCKETBASE_URL=http://127.0.0.1:8090

# Optional data directory for serve.sh (default ./pb_data)
# PB_DATA_DIR=./pb_data

# Web app (set in apps/web/.env — listed here for convenience)
# VITE_POCKETBASE_URL=http://127.0.0.1:8090
